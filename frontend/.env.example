# === Me4BrAIn Connection ===
ME4BRAIN_URL=http://localhost:8000
ME4BRAIN_API_KEY=

# === Gateway ===
PORT=3030
HOST=0.0.0.0
LOG_LEVEL=info

# === Redis (Session Persistence) ===
# Uses Me4BrAIn Redis on port 6389 (no password required)
# If using local Redis with auth, set REDIS_PASSWORD
REDIS_URL=redis://localhost:6389
REDIS_PASSWORD=

# === Backend ===
PERSAN_PORT=8888
PERSAN_HOST=0.0.0.0
DEBUG=true

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8888
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:3030/ws

# === Auth (predisposto, disabilitato in dev) ===
AUTH_ENABLED=false

# === Telegram Channel ===
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Optional: comma-separated usernames to whitelist
TELEGRAM_ALLOWED_USERS=

# === WhatsApp Channel ===
# ⚠️ WARNING: Current Baileys implementation uses YOUR personal WhatsApp!
# Anyone messaging you would get AI responses instead of you.
# Keep disabled until WhatsApp Cloud API is implemented.
# WHATSAPP_ENABLED=false
# WHATSAPP_AUTH_DIR=./data/whatsapp-auth
# WHATSAPP_ALLOWED_NUMBERS=

# === Voice TTS ===
# TTS uses Web Speech API in browser (no server-side config needed)
