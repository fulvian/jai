# Me4BrAIn Core Environment Variables
# Copy to .env and fill in values

# =============================================================================
# API Configuration
# =============================================================================
ME4BRAIN_HOST=0.0.0.0
ME4BRAIN_PORT=8089
ME4BRAIN_DEBUG=true
ME4BRAIN_LOG_LEVEL=DEBUG

# API Key Authentication (vuoto = nessuna auth richiesta, per sviluppo)
# Per produzione, impostare un valore segreto
ME4BRAIN_API_KEY=

# =============================================================================
# Database Connections (Porte Desuete per evitare conflitti)
# =============================================================================

# PostgreSQL (LangGraph Checkpointing)
POSTGRES_HOST=localhost
POSTGRES_PORT=5489
POSTGRES_USER=me4brain
POSTGRES_PASSWORD=me4brain_secret_change_me
POSTGRES_DB=me4brain

# Redis (Working Memory / Cache)
REDIS_HOST=localhost
REDIS_PORT=6389
REDIS_PASSWORD=

# Qdrant (Vector Store)
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6389
QDRANT_HTTP_PORT=6390

# Neo4j (Graph Database Secondary)
NEO4J_HOST=localhost
NEO4J_HTTP_PORT=7478
NEO4J_BOLT_PORT=7697
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret_change_me

# KuzuDB (Graph Database Primary - Embedded)
KUZU_DB_PATH=./data/kuzu

# =============================================================================
# Keycloak (Authentication)
# =============================================================================
KEYCLOAK_URL=http://localhost:8489
KEYCLOAK_REALM=me4brain
KEYCLOAK_CLIENT_ID=me4brain-api
KEYCLOAK_CLIENT_SECRET=change_me_in_production

# =============================================================================
# LLM Configuration (NanoGPT)
# =============================================================================
NANOGPT_API_KEY=your_nanogpt_api_key_here
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1

# Models Configuration (Jan 2026 Benchmarks)
# Primary: DeepSeek V3.2 Speciale (96% AIME)
LLM_PRIMARY_MODEL=deepseek/deepseek-v3.2-speciale
LLM_PRIMARY_THINKING_MODEL=deepseek/deepseek-v3.2-speciale

# Agentic: GLM 4.7 (42.8% HLE Tool)
LLM_AGENTIC_MODEL=zai-org/glm-4.7:thinking
LLM_AGENTIC_FAST_MODEL=zai-org/glm-4.7

# Vision/Long Context: Kimi K2.5 (SOTA Vision, 256K Context)
LLM_VISION_MODEL=moonshotai/kimi-k2.5:thinking

# Fallback
LLM_FALLBACK_MODEL=deepseek/deepseek-v3.2

# =============================================================================
# Embedding Model
# =============================================================================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=mps  # mps | cuda | cpu

# =============================================================================
# Multi-Tenancy
# =============================================================================
DEFAULT_TENANT_ID=default
TENANT_ISOLATION_MODE=payload_filter  # payload_filter | collection_per_tenant

# =============================================================================
# Travel Domain - Flight Search & Accommodation
# =============================================================================
# Amadeus Self-Service (Free tier - https://developers.amadeus.com)
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Google Places API (https://developers.google.com/maps/documentation/places)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# =============================================================================
# Finance Domain - Stock & Crypto Data
# =============================================================================
# Financial Modeling Prep (https://financialmodelingprep.com)
FMP_API_KEY=your_fmp_api_key

# Finnhub (https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key

# =============================================================================
# Google Workspace - OAuth Token
# =============================================================================
# OAuth token for Gmail, Calendar, Drive access
GOOGLE_OAUTH_TOKEN=your_google_oauth_token
