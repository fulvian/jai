# =============================================================================
# Me4Brain Production Environment - GeekCom Server
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# API Configuration
ME4BRAIN_HOST=0.0.0.0
ME4BRAIN_PORT=8089
ME4BRAIN_DEBUG=false
ME4BRAIN_LOG_LEVEL=INFO
ME4BRAIN_API_KEY=

# Database Connections (Docker internal hostnames)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=me4brain
POSTGRES_PASSWORD=me4brain_secret_change_me
POSTGRES_DB=me4brain
DB_PASSWORD=me4brain_secret_change_me

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

QDRANT_HOST=qdrant
QDRANT_GRPC_PORT=6333
QDRANT_HTTP_PORT=6334

NEO4J_HOST=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret_change_me

# KuzuDB (embedded)
KUZU_DB_PATH=./data/kuzu

# Keycloak (optional)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=me4brain
KEYCLOAK_CLIENT_ID=me4brain-api
KEYCLOAK_CLIENT_SECRET=change_me_in_production
KEYCLOAK_PASSWORD=admin_secret

# LLM Configuration (NanoGPT)
NANOGPT_API_KEY=your_nanogpt_api_key_here
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1

# Models Configuration - MISTRAL LARGE 3
LLM_PRIMARY_MODEL=mistralai/mistral-large-3-675b-instruct-2512
LLM_PRIMARY_THINKING_MODEL=mistralai/mistral-large-3-675b-instruct-2512
LLM_AGENTIC_MODEL=mistralai/mistral-large-3-675b-instruct-2512
LLM_AGENTIC_FAST_MODEL=mistralai/mistral-large-3-675b-instruct-2512
LLM_VISION_MODEL=mistralai/mistral-large-3-675b-instruct-2512
LLM_FALLBACK_MODEL=mistralai/mistral-large-3-675b-instruct-2512

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# Multi-Tenancy
DEFAULT_TENANT_ID=default
TENANT_ISOLATION_MODE=payload_filter

# Production
ENVIRONMENT=production
