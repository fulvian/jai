# =============================================================================
# Me4BrAIn Docker Environment
# =============================================================================
# Copy this file to .env and customize

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_PORT=8000
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Database Passwords (CHANGE IN PRODUCTION!)
# -----------------------------------------------------------------------------
DB_PASSWORD=me4brain_secret_change_me
NEO4J_PASSWORD=neo4j_secret_change_me
KEYCLOAK_PASSWORD=admin_secret_change_me

# -----------------------------------------------------------------------------
# Port Mappings (avoid conflicts with other projects)
# -----------------------------------------------------------------------------
POSTGRES_PORT=5489
REDIS_PORT=6389
QDRANT_GRPC_PORT=6333
QDRANT_HTTP_PORT=6334
NEO4J_HTTP_PORT=7478
NEO4J_BOLT_PORT=7697
KEYCLOAK_PORT=8489

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------
NANOGPT_API_KEY=your_nanogpt_api_key_here
