# ============================================================================
# Me4BrAIn Backend - Environment Variables Normalized
# ============================================================================
# This file documents the CORRECT environment variables that settings.py
# expects, aligned with the deployment plan 2026-03-25.
#
# IMPORTANT: These variable names must match what src/me4brain/config/settings.py
# expects via its pydantic aliases and ME4BRAIN_ prefix.
#
# The .env file at backend/.env should contain these variables (without # comments
# since python-dotenv doesn't support inline comments on value lines).
# ============================================================================

# --------------------------------------------------------------------------
# API Configuration (Me4BrAIn Core)
# --------------------------------------------------------------------------
ME4BRAIN_HOST=localhost
ME4BRAIN_PORT=8000
ME4BRAIN_DEBUG=true
ME4BRAIN_LOG_LEVEL=DEBUG
ME4BRAIN_CORS_ORIGINS=http://localhost:3020,http://localhost:3030,http://localhost:8000

# --------------------------------------------------------------------------
# PostgreSQL (LangGraph Checkpointing)
# NOTE: settings.py uses POSTGRES_* aliases, NOT DB_*
# --------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jai_user
POSTGRES_PASSWORD=jai_password
POSTGRES_DB=me4brain

# --------------------------------------------------------------------------
# Redis (Working Memory)
# NOTE: settings.py uses REDIS_* variables, NOT separate REDIS_URL
# --------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --------------------------------------------------------------------------
# Qdrant (Vector Store)
# --------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --------------------------------------------------------------------------
# Neo4j (Graph Database Secondary)
# --------------------------------------------------------------------------
NEO4J_HOST=localhost
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# --------------------------------------------------------------------------
# Keycloak (Authentication)
# --------------------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8489
KEYCLOAK_REALM=me4brain
KEYCLOAK_CLIENT_ID=me4brain-api
KEYCLOAK_CLIENT_SECRET=change_me_in_production

# --------------------------------------------------------------------------
# LLM Providers
# --------------------------------------------------------------------------
LLM_PRIMARY_PROVIDER=openai
LLM_PRIMARY_MODEL=gpt-4o
OPENAI_API_KEY=

LLM_SECONDARY_PROVIDER=google
LLM_SECONDARY_MODEL=gemini-1.5-flash
GOOGLE_API_KEY=

# --------------------------------------------------------------------------
# Embedding Model
# NOTE: Default changed from 'mps' to 'cpu' due to 94% VRAM utilization
# --------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# --------------------------------------------------------------------------
# Multi-Tenancy
# --------------------------------------------------------------------------
DEFAULT_TENANT_ID=me4brain_core
TENANT_ISOLATION_MODE=payload_filter

# --------------------------------------------------------------------------
# API Key Authentication
# --------------------------------------------------------------------------
ME4BRAIN_API_KEY=
ME4BRAIN_API_KEY_HEADER=X-API-Key

# --------------------------------------------------------------------------
# Runtime
# --------------------------------------------------------------------------
PYTHONUNBUFFERED=1
ENVIRONMENT=development
